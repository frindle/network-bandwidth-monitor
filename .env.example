# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Static IP for this container on your LAN (must be free)
CONTAINER_IP=10.0.x.x

# Path where the SQLite database is stored inside the container
DB_PATH=/data/netmon.db

# Path where /proc/net is mounted from the host
NET_BASE=/host/net

# Your LAN subnet (used to detect local vs external traffic)
LOCAL_SUBNET=10.0.0.0/20

# Name of your Cloudflare Tunnel Docker container
CF_TUNNEL_CONTAINER=CloudflareTunnel

# Comma-separated interface names to exclude from bandwidth charts
# Common candidates: VLANs, unused NICs, VM bridges, VPN interfaces
IGNORE_INTERFACES=bond0.10,br0.10,eth2,eth3,tailscale1,virbr0,vnet0
